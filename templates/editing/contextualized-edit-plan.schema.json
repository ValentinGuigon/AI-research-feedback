{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contextualized Edit Plan",
  "description": "Location-aware edit instructions derived from a revision plan and writing constraints for a single source document.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_version",
    "document_type",
    "source_document_path",
    "revision_plan_path",
    "writing_constraints_path",
    "generated_at",
    "revision_targets"
  ],
  "properties": {
    "artifact_version": {
      "type": "string"
    },
    "document_type": {
      "type": "string",
      "enum": [
        "grant",
        "paper",
        "pap",
        "paper-code"
      ]
    },
    "source_document_path": {
      "type": "string"
    },
    "revision_plan_path": {
      "type": "string"
    },
    "writing_constraints_path": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "context_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "previous_contextualized_edit_plan_path": {
      "type": "string"
    },
    "previous_drafted_edit_instructions_path": {
      "type": "string"
    },
    "projected_revision_state_path": {
      "type": "string"
    },
    "edit_review_panel_report_path": {
      "type": "string"
    },
    "iteration_reason": {
      "type": "string"
    },
    "local_assessment_summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "global_assessment_summary": {
      "type": "string"
    },
    "accepted_prior_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revised_prior_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_or_rolled_back_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tradeoff_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revision_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "priority",
          "issue",
          "location",
          "suggestion",
          "motivation",
          "constraint_checks",
          "source_evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "issue": {
            "type": "string"
          },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "section"
            ],
            "properties": {
              "section": {
                "type": "string"
              },
              "heading_match": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "paragraph_hint": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "text_quote": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "source_path": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "suggestion": {
            "type": "string"
          },
          "motivation": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "propagation_targets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "section",
                "reason"
              ],
              "properties": {
                "section": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "constraint_checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "source_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "review_path",
                "quote_or_summary"
              ],
              "properties": {
                "review_path": {
                  "type": "string"
                },
                "review_section": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "quote_or_summary": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
