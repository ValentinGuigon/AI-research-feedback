{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Projected Revision State",
  "description": "Structured review evidence describing the document state implied by drafted edit instructions without rewriting the source document.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_version",
    "document_type",
    "source_document_path",
    "drafted_edit_instructions_path",
    "contextualized_edit_plan_path",
    "generated_at",
    "projection_mode",
    "projection_boundary",
    "baseline_references",
    "applied_instruction_map",
    "unresolved_items",
    "source_local_uncertainties",
    "projection_notes"
  ],
  "properties": {
    "artifact_version": {
      "type": "string"
    },
    "document_type": {
      "type": "string",
      "enum": [
        "grant",
        "paper",
        "pap",
        "paper-code"
      ]
    },
    "source_document_path": {
      "type": "string"
    },
    "drafted_edit_instructions_path": {
      "type": "string"
    },
    "contextualized_edit_plan_path": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "projection_mode": {
      "type": "string",
      "enum": [
        "structured-field",
        "structured-section",
        "text-excerpt",
        "object-specific"
      ]
    },
    "projection_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_rewrite_performed",
        "tracked_changes_created",
        "review_evidence_only",
        "notes"
      ],
      "properties": {
        "source_rewrite_performed": {
          "const": false
        },
        "tracked_changes_created": {
          "const": false
        },
        "review_evidence_only": {
          "const": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "baseline_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "source_path",
          "reference_type",
          "used_for"
        ],
        "properties": {
          "source_path": {
            "type": "string"
          },
          "reference_type": {
            "type": "string"
          },
          "used_for": {
            "type": "string"
          }
        }
      }
    },
    "applied_instruction_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "instruction_id",
          "target_id",
          "action_type",
          "application_status",
          "projected_local_result",
          "provenance"
        ],
        "properties": {
          "instruction_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "action_type": {
            "type": "string"
          },
          "application_status": {
            "type": "string",
            "enum": [
              "complete",
              "partial",
              "rejected",
              "verification-blocked"
            ]
          },
          "projected_local_result": {
            "type": "string"
          },
          "provenance": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "drafted_edit_instructions_path",
              "contextualized_edit_plan_path"
            ]
          }
        }
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "instruction_id",
          "reason",
          "needed_human_check"
        ],
        "properties": {
          "instruction_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "needed_human_check": {
            "type": "string"
          }
        }
      }
    },
    "source_local_uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "projection_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
