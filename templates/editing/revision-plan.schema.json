{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post-Review Revision Plan",
  "description": "Normalized revision targets derived from one or more review reports for a single source document.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_version",
    "document_type",
    "source_document_path",
    "review_paths",
    "generated_at",
    "revision_targets"
  ],
  "properties": {
    "artifact_version": {
      "type": "string"
    },
    "document_type": {
      "type": "string",
      "enum": [
        "grant",
        "paper",
        "pap",
        "paper-code"
      ]
    },
    "source_document_path": {
      "type": "string"
    },
    "review_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string"
    },
    "plan_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revision_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "priority",
          "issue",
          "edit_intent",
          "motivation",
          "source_evidence",
          "candidate_locations"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "issue": {
            "type": "string"
          },
          "edit_intent": {
            "type": "string",
            "enum": [
              "add",
              "clarify",
              "qualify",
              "restructure",
              "compress",
              "remove",
              "align",
              "verify"
            ]
          },
          "motivation": {
            "type": "string"
          },
          "source_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "review_path",
                "quote_or_summary"
              ],
              "properties": {
                "review_path": {
                  "type": "string"
                },
                "review_section": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "finding_id": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "quote_or_summary": {
                  "type": "string"
                }
              }
            }
          },
          "candidate_locations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reason"
              ],
              "properties": {
                "section_hint": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "heading_hint": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "paragraph_hint": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
